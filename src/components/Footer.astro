---
const year = new Date().getFullYear();
const company = {
  name: 'VERVE Water Mobility GmbH',
  address: 'Carl-Benz-Str. 1, D-79331 Teningen',
  phone: '+49 7663 9317-996',
  email: 'hi@sylents.de',
};
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/sylents-2c_1.svg" alt="Sylents" width="125" height="37" />
      <p class="tagline">The first jet for broad leisure use.</p>
    </div>
    <div class="footer-col">
      <h4>Products</h4>
      <a href="/#products">Outboard</a>
      <a href="/#products">Inboard</a>
      <a href="/#products">Pod drive</a>
    </div>
    <div class="footer-col">
      <h4>Company</h4>
      <a href="/#company">About</a>
      <a href="/#company">Team</a>
      <a href="/#company">Career</a>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <a href={`mailto:${company.email}`}>{company.email}</a>
      <a href={`tel:${company.phone.replace(/\s/g, '')}`}>{company.phone}</a>
      <p class="addr">{company.name}<br />{company.address}</p>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {year} {company.name}</span>
    <nav class="legal-nav">
      <a href="/imprint">Imprint</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
  </div>
</footer>

<style>
.site-footer {
  margin-top: auto;
  border-top: 1px solid var(--color-border);
  background: rgba(10, 10, 10, 0.6);
  padding-block: var(--spacing-70) var(--spacing-40);
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 2.5rem;
  padding-bottom: var(--spacing-50);
}
.footer-brand img { height: 30px; margin-bottom: 0.75rem; }
.tagline { font-size: 0.9rem; color: var(--color-text-muted); }
.footer-col h4 {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 0.75rem;
  font-weight: 600;
}
.footer-col a, .footer-col p {
  display: block;
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  margin-bottom: 0.4rem;
}
.footer-col a:hover { color: var(--color-light); }
.addr { margin-top: 0.5rem; }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.5rem;
  border-top: 1px solid var(--color-border);
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
.legal-nav { display: flex; gap: 1.5rem; }
.legal-nav a { color: var(--color-text-muted); }
.legal-nav a:hover { color: var(--color-light); }
@media (max-width: 720px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-bottom { flex-direction: column; gap: 1rem; }
}
</style>
