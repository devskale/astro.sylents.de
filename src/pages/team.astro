---
import SiteLayout from '../layouts/SiteLayout.astro';
import '../styles/tokens.css';

const team = [
  {
    name: 'Hilmar Unterrainer',
    role: 'Co-Founder · Industrial Engineer',
    img: '/team/hilmar.png',
    bio: 'Hintergrund in Elektronik und Betriebswirtschaft. Langjährige Erfahrung in der Projektleitung und in der Entwicklung elektrischer Antriebe.',
  },
  {
    name: 'Johann Waldherr',
    role: 'Co-Founder · MSc Computer Science',
    img: '/team/hans.jpg',
    bio: 'Master in Computertechnik. Schwerpunkt auf Embedded Systems und Robotics.',
  },
  {
    name: 'Philipp',
    role: 'Mechatronics',
    img: '/team/philipp.png',
    bio: 'Absolvent der Höheren Technischen Bundeslehranstalt Wels, Mechatroniker mit Praxis in der elektrischen Antriebstechnik.',
  },
  {
    name: 'Christian',
    role: 'Electronics Engineer',
    img: '/team/christian.png',
    bio: 'Embedded Hardware- und Softwareentwicklung – von der Baugruppe über Kommunikationstechnik bis zum kompletten System.',
  },
  {
    name: 'Peter',
    role: 'Mechatronics / Robotics',
    img: '/team/peter.jpg',
    bio: 'Master in Robotik und Kybernetik. Erfahrener Produktentwickler für unterschiedlichste Branchen mit mehreren marktreifen Produkten.',
  },
  {
    name: 'Matej',
    role: 'PhD Hydrodynamics / CFD',
    img: '/team/matej.jpg',
    bio: 'Promotion in Hydrodynamik mit Schwerpunkt auf der Optimierung hydraulischer Maschinen und CFD-Simulationen.',
  },
];
---

<SiteLayout title="Team | Sylents" description="Das Sylents-Team: erfahrene Ingenieure für Elektromobilität, Hydrodynamik und Embedded Systems.">
  <section class="page-hero">
    <div class="container">
      <span class="breadcrumb">Team</span>
      <h1>Das Team hinter Sylents</h1>
      <p>Spezialisten aus Elektromobilität, Hydrodynamik und Embedded Systems – vereint von der Idee, leise und emissionsfrei über das Wasser zu gleiten.</p>
    </div>
  </section>

  <!-- Origin story -->
  <section class="story">
    <div class="container story-grid">
      <div>
        <span class="eyebrow">So fing es an</span>
        <h2>Vom Strand in die Werkstatt.</h2>
        <p>Alles begann im Urlaub: Wir lagen am Strand, genossen die Ruhe und die Weite des Meeres – bis ein lautes, stinkendes Wassermotorrad die Stille brach. Genug Grund, etwas zu ändern. Die Idee war geboren: ein elektrischer Wasserstrahlantrieb, wie es ihn noch nicht gab.</p>
        <p>Heute ist Sylents einer der ersten Hersteller für elektrische Jetantriebe im Freizeitboote-Segment – sicher, blockierungsfrei und emissionsfrei.</p>
      </div>
      <div class="story-stats">
        <div><strong>2019</strong><span>gegründet</span></div>
        <div><strong>6+</strong><span>Spezialisten</span></div>
        <div><strong>1–10 kW</strong><span>Antriebsleistung</span></div>
      </div>
    </div>
  </section>

  <!-- Team grid -->
  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        {team.map((m) => (
          <article class="member-card">
            <div class="member-img"><img src={m.img} alt={m.name} /></div>
            <h3>{m.name}</h3>
            <p class="member-role">{m.role}</p>
            <p class="member-bio">{m.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>

<style>
.story { padding: 80px 0; background: var(--color-bg-alt); }
.story-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 4rem; align-items: center; }
.story h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 1rem; }
.story p { color: #444; line-height: 1.8; font-size: 1.05rem; margin-bottom: 1rem; }
.story-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.story-stats div {
  background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm); padding: 1.5rem 1rem; text-align: center;
}
.story-stats strong { display: block; font-size: 1.6rem; color: var(--color-primary); }
.story-stats span { font-size: 0.82rem; color: #777; }

.team-section { padding: 80px 0; }
.team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.member-card {
  background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm); padding: 2rem; text-align: center;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.member-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.member-img {
  width: 120px; height: 120px; margin: 0 auto 1.25rem; border-radius: 50%;
  overflow: hidden; border: 3px solid rgba(0,188,212,0.25);
  background: linear-gradient(160deg, #f1f7f9, #dbeaee);
}
.member-img img { width: 100%; height: 100%; object-fit: cover; }
.member-card h3 { font-size: 1.15rem; color: var(--color-primary-dark); margin-bottom: 0.25rem; }
.member-role { color: var(--color-primary); font-size: 0.88rem; font-weight: 600; margin-bottom: 0.75rem; }
.member-bio { color: #666; font-size: 0.9rem; line-height: 1.6; }
@media (max-width: 900px) {
  .story-grid { grid-template-columns: 1fr; gap: 2rem; }
  .team-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .team-grid { grid-template-columns: 1fr; }
}
</style>
