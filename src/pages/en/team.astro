---
import SiteLayout from '../../layouts/SiteLayout.astro';
import '../../styles/tokens.css';

const team = [
  { name: 'Hilmar Unterrainer', role: 'Co-Founder · Industrial Engineer', img: '/team/hilmar.png', bio: 'Background in electronics and business administration. Years of experience in project management and in developing electric drives.' },
  { name: 'Johann Waldherr', role: 'Co-Founder · MSc Computer Engineering', img: '/team/hans.jpg', bio: 'Master in Computer Engineering, with a focus on embedded systems and robotics.' },
  { name: 'Philipp', role: 'Mechatronics', img: '/team/philipp.png', bio: 'Graduate of the Higher Technical Institute Wels, mechatronics engineer with hands-on experience in electric drive technology.' },
  { name: 'Christian', role: 'Electronics Engineer', img: '/team/christian.png', bio: 'Embedded hardware and software development – from components and communications technology to complete systems.' },
  { name: 'Peter', role: 'Mechatronics / Robotics', img: '/team/peter.jpg', bio: 'Master in robotics and cybernetics. Experienced product developer across several industries with multiple market-ready products.' },
  { name: 'Matej', role: 'PhD Hydrodynamics / CFD', img: '/team/matej.jpg', bio: 'PhD in hydrodynamics, focused on optimising hydraulic machines and CFD simulations.' },
];
---

<SiteLayout lang="en" title="Team | Sylents" description="The Sylents team: experienced engineers in e-mobility, hydrodynamics and embedded systems.">
  <section class="page-hero"><div class="container">
    <span class="breadcrumb">Team</span>
    <h1>The team behind Sylents</h1>
    <p>Specialists in e-mobility, hydrodynamics and embedded systems – united by the idea of gliding across the water silently and emission-free.</p>
  </div></section>

  <section class="story"><div class="container story-grid">
    <div>
      <span class="eyebrow">How it started</span>
      <h2>From the beach to the workshop.</h2>
      <p>It all started on holiday: we were lying on the beach, enjoying the calm and the vastness of the sea – until a loud, foul-smelling personal watercraft broke the silence. Reason enough to change something. The idea was born: an electric water-jet drive like none before it.</p>
      <p>Today, Sylents is one of the first manufacturers of electric jet drives for the leisure-boating segment – safe, blockage-free and emission-free.</p>
    </div>
    <div class="story-stats">
      <div><strong>2019</strong><span>founded</span></div>
      <div><strong>6+</strong><span>specialists</span></div>
      <div><strong>1–10 kW</strong><span>drive power</span></div>
    </div>
  </div></section>

  <section class="team-section"><div class="container"><div class="team-grid">
    {team.map((m) => (
      <article class="member-card">
        <div class="member-img"><img src={m.img} alt={m.name} /></div>
        <h3>{m.name}</h3>
        <p class="member-role">{m.role}</p>
        <p class="member-bio">{m.bio}</p>
      </article>
    ))}
  </div></div></section>
</SiteLayout>

<style>
.story { padding: 80px 0; background: var(--color-bg-alt); }
.story-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 4rem; align-items: center; }
.story h2 { font-size: clamp(1.6rem,3vw,2.2rem); margin-bottom: 1rem; }
.story p { color: #444; line-height: 1.8; font-size: 1.05rem; margin-bottom: 1rem; }
.story-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
.story-stats div { background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 1.5rem 1rem; text-align: center; }
.story-stats strong { display: block; font-size: 1.6rem; color: var(--color-primary); }
.story-stats span { font-size: 0.82rem; color: #777; }
.team-section { padding: 80px 0; }
.team-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; }
.member-card { background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 2rem; text-align: center; transition: transform 0.25s, box-shadow 0.25s; }
.member-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.member-img { width: 120px; height: 120px; margin: 0 auto 1.25rem; border-radius: 50%; overflow: hidden; border: 3px solid rgba(0,188,212,0.25); background: linear-gradient(160deg,#f1f7f9,#dbeaee); }
.member-img img { width: 100%; height: 100%; object-fit: cover; }
.member-card h3 { font-size: 1.15rem; color: var(--color-primary-dark); margin-bottom: 0.25rem; }
.member-role { color: var(--color-primary); font-size: 0.88rem; font-weight: 600; margin-bottom: 0.75rem; }
.member-bio { color: #666; font-size: 0.9rem; line-height: 1.6; }
@media (max-width: 900px) { .story-grid { grid-template-columns: 1fr; gap: 2rem; } .team-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 560px) { .team-grid { grid-template-columns: 1fr; } }
</style>
