---
import SiteLayout from '../../layouts/SiteLayout.astro';
import '../../styles/tokens.css';

const perks = [
  { title: 'Meaningful', desc: 'You work on emission-free mobility on the water – with a real impact on nature and people.', icon: '<path d="M12 21s-7-4.5-7-11a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 6.5-7 11-7 11z"/><path d="M12 9c2 2 4 2 4 2"/>' },
  { title: 'Hands-on & direct', desc: 'Short decision paths, flat hierarchies: the best argument counts, not who makes it.', icon: '<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2-2 2.5-2.5z"/>' },
  { title: 'Growth', desc: 'A young scale-up moving from prototype to series – with plenty of room for ownership.', icon: '<path d="M3 17l6-6 4 4 8-8"/><path d="M17 7h4v4"/>' },
  { title: 'Strong team', desc: 'Specialists in e-mobility, hydrodynamics and embedded systems who learn from each other.', icon: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/><path d="M16 11a3 3 0 0 0 0-6"/><path d="M15 15c3 0 5.5 2 5.5 5"/>' },
];
---

<SiteLayout lang="en" title="Career | Sylents" description="Career at Sylents – work on emission-free jet drives for leisure boats.">
  <section class="page-hero"><div class="container">
    <span class="breadcrumb">Career</span>
    <h1>Shape mobility on the water.</h1>
    <p>We develop electric jet drives for leisure boats – and we are growing. If you want to work on emission-free technology that truly moves things, you belong with us.</p>
  </div></section>

  <section class="perks"><div class="container">
    <span class="eyebrow">Why Sylents</span>
    <h2>What awaits you.</h2>
    <div class="perks-grid">
      {perks.map((p) => (
        <div class="perk-card">
          <div class="perk-icon"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="#00bcd4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} /></div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>
  </div></section>

  <section class="jobs"><div class="container">
    <span class="eyebrow">Open positions</span>
    <h2>Current opportunities.</h2>
    <div class="jobs-list">
      <a href="mailto:hi@sylents.de?subject=Application%20CFD" class="job-row"><div><h3>Development Engineer CFD (m/f/d)</h3><p>Working student / thesis · Teningen or remote</p></div><span class="job-arrow">→</span></a>
      <a href="mailto:hi@sylents.de?subject=Application%20Technical%20Assistant" class="job-row"><div><h3>Technical Assistant (m/f/d)</h3><p>Full-time · Teningen</p></div><span class="job-arrow">→</span></a>
      <a href="mailto:hi@sylents.de?subject=Open%20application" class="job-row"><div><h3>Open application</h3><p>You don't fit a box? Tell us what you can contribute.</p></div><span class="job-arrow">→</span></a>
    </div>
    <p class="jobs-note">We look forward to your application at <a href="mailto:hi@sylents.de">hi@sylents.de</a>.</p>
  </div></section>
</SiteLayout>

<style>
.perks { padding: 80px 0; background: var(--color-bg-alt); }
.perks h2 { font-size: clamp(1.6rem,3vw,2.2rem); margin-bottom: 2.5rem; }
.perks-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.5rem; }
.perk-card { background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 1.75rem; transition: transform 0.25s, box-shadow 0.25s; }
.perk-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.perk-icon { width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; background-image: linear-gradient(135deg, rgba(0,188,212,0.14), rgba(0,188,212,0.04)); border: 1px solid rgba(0,188,212,0.18); border-radius: 14px; margin-bottom: 1.1rem; }
.perk-card h3 { font-size: 1.1rem; color: var(--color-primary-dark); margin-bottom: 0.4rem; }
.perk-card p { color: #666; font-size: 0.9rem; line-height: 1.55; }
.jobs { padding: 80px 0; }
.jobs h2 { font-size: clamp(1.6rem,3vw,2.2rem); margin-bottom: 2rem; }
.jobs-list { display: flex; flex-direction: column; gap: 1rem; }
.job-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; background: #fff; border: 1px solid rgba(13,31,36,0.08); border-radius: var(--radius-md); padding: 1.4rem 1.6rem; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
.job-row:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: rgba(0,188,212,0.4); }
.job-row h3 { font-size: 1.1rem; color: #1a3c44; margin-bottom: 0.2rem; }
.job-row p { color: #777; font-size: 0.9rem; }
.job-arrow { color: var(--color-primary); font-size: 1.4rem; font-weight: 600; }
.jobs-note { margin-top: 2rem; color: #555; }
.jobs-note a { color: var(--color-primary-dark); }
@media (max-width: 900px) { .perks-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 560px) { .perks-grid { grid-template-columns: 1fr; } }
</style>
