---
import SiteLayout from '../../layouts/SiteLayout.astro';
import '../../styles/tokens.css';

const partners = [
  { src: '/partner-zentipe.svg', alt: 'Zentipe Innovation AG' },
  { src: '/partner-skale.svg', alt: 'skale.io' },
  { src: '/partner-bild2.png', alt: 'partner' },
  { src: '/partner-mpe.png', alt: 'MPE Ventures' },
  { src: '/partner-bwcon.png', alt: 'bwcon' },
  { src: '/partner-bild4.png', alt: 'partner' },
  { src: '/partner-bild5.png', alt: 'partner' },
];

const benefits = [
  {
    icon: '<circle cx="12" cy="12" r="9"/><path d="M8.5 8.5l4 2.5 2.5 4-4-2.5z"/>',
    title: 'Agile & direct',
    body: 'Instant thrust from a standstill and effortless maneuvering – the typical jet feel that no propeller offers.',
  },
  {
    icon: '<path d="M2 18c1.5 0 1.5 1.5 3 1.5S6.5 18 8 18s1.5 1.5 3 1.5S12.5 18 14 18s1.5 1.5 3 1.5S18.5 18 20 18s1.5 1.5 3 1.5"/><circle cx="12" cy="7" r="3"/><path d="M5 21c0-3.9 3.1-7 7-7"/>',
    title: 'Safe in shallow waters',
    body: 'No external moving parts – safe for swimmers. And ideal for shallow shores, reed beds and harbours, where propellers fail.',
  },
  {
    icon: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
    title: 'Available as outboard, inboard & pod',
    body: 'Since Sylents, there is a matching jet drive for every leisure boat on the lake.',
  },
];

const products = [
  { img: '/inboard.png', alt: 'inboard', name: 'inboard', desc: 'Integrated electric drive for permanent installation – quiet, low-maintenance, ideal for sheltered waters.', power: '1–10 kW', href: '/en/products/#inboard' },
  { img: '/outboard.png', alt: 'outboard', name: 'outboard', desc: 'The lightweight outboard – mounted in minutes and ready to launch from anywhere.', power: '1.2–4.5 kW', href: '/en/products/#outboard' },
  { img: '/pod.png', alt: 'Pod', name: 'Pod', desc: 'Compact pod drive for sailboats and shallow waters – space-saving with complete energy management.', power: '1–10 kW', href: '/en/products/' },
];
---

<SiteLayout lang="en" title="Sylents — Electric jet drives for leisure boats" description="Electric jet drives for leisure boats – silent, emission-free, blockage-free. Available as outboard, inboard and pod.">
  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <img src="/sylents-claim.svg" alt="sylents-claim" class="hero-claim" />
      <h3>Jet fun on the lakes.</h3>
    </div>
  </section>

  <!-- Partners -->
  <section class="partners-section">
    <div class="container"><p class="partners-label">supported by</p></div>
    <div class="partner-logos-wrapper">
      <div class="partner-logos-track">
        {[...partners, ...partners].map((p) => (
          <div class="logo-slot"><img src={p.src} alt={p.alt} loading="lazy" /></div>
        ))}
      </div>
      <div class="fade fade-left"></div>
      <div class="fade fade-right"></div>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro-section">
    <div class="container intro-grid">
      <div class="intro-text">
        <span class="eyebrow">Electric jet drives</span>
        <h2>Silent. Powerful. Emission-free.</h2>
        <p class="lead">Sylents develops and produces electric water-jet drives with an internal electric motor – water-cooled, blockage-free and with a closed impeller. For lasting fun on lakes and along the coast.</p>
        <ul class="intro-tags">
          <li>Silent</li><li>Emission-free</li><li>Blockage-free</li><li>Low-maintenance</li><li>Safe for swimmers</li>
        </ul>
      </div>
      <div class="intro-visual"><img src="/outboard.png" alt="Sylents outboard" /></div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="benefits-section">
    <div class="container">
      <div class="benefits-head">
        <span class="eyebrow">Jet Experience</span>
        <h2>What sets jets apart.</h2>
        <p class="benefits-lead">For a long time, jets were a niche solution. Sylents makes them the standard – for every leisure boat on the lake.</p>
      </div>
      <div class="benefits-grid">
        {benefits.map((b) => (
          <div class="benefit-card">
            <div class="benefit-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#00bcd4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} />
            </div>
            <h3>{b.title}</h3>
            <p>{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="products-section">
    <div class="container">
      <h2>Our products & services</h2>
      <div class="products-grid">
        {products.map((p) => (
          <div class="product-card">
            <img src={p.img} alt={p.alt} />
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
            <p class="version"><strong>Power:</strong> {p.power}</p>
            <a href={p.href}>Learn more...</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact-section">
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Any questions?</h2>
        <h3>Get in touch –<br />we answer at any tide</h3>
        <p>Leave your name and contact details – we reply within 48 hours or less.</p>
        <p>Hans Waldherr, Co-Founder</p>
        <p>Hilmar Unterrainer, Co-Founder</p>
        <p>tel <a href="tel:+4976639317996">+49 7663 9317-996</a></p>
        <p>email <a href="mailto:hi@sylents.de">hi@sylents.de</a></p>
      </div>
      <div class="contact-form">
        <form>
          <input type="text" name="name" placeholder="Name *" required />
          <input type="email" name="email" placeholder="Email *" required />
          <textarea name="message" placeholder="Message *" required></textarea>
          <label class="consent">
            <input type="checkbox" required />
            <span>I accept the <a href="/en/privacy/">privacy policy</a>*</span>
          </label>
          <button type="submit" class="btn">Send</button>
        </form>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
.hero-section { min-height: 80vh; display: flex; align-items: flex-start; justify-content: center; text-align: center; position: relative;
  background-image: linear-gradient(rgba(0,90,120,0.3), rgba(0,50,70,0.55)), url('/kajak.jpg'); background-size: cover; background-position: center; padding: 130px 0 80px; }
.hero-section::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 30%, rgba(0,188,212,0.18), transparent 55%); pointer-events: none; }
.hero-section .container { position: relative; z-index: 1; }
.hero-claim { max-width: 350px; margin: 0 auto 2rem; }
.hero-section h3 { font-family: 'Montserrat', sans-serif; font-size: clamp(1.6rem,4vw,2.4rem); font-weight: 300; line-height: 1.22; color: #fff; text-shadow: 0 2px 24px rgba(0,30,40,0.5); }

.partners-section { padding: 24px 0 40px; text-align: center; background: var(--color-bg-alt); overflow: hidden; }
.partners-label { color: #666; margin-bottom: 1.5rem; font-size: 0.9rem; }
.partner-logos-wrapper { position: relative; width: 100%; overflow: hidden; }
.partner-logos-track { display: flex; gap: 1.5rem; width: max-content; animation: partner-scroll 32s linear infinite; }
@keyframes partner-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(calc(-50% - 0.75rem)); } }
.logo-slot { flex-shrink: 0; width: 120px; height: 60px; display: flex; align-items: center; justify-content: center; padding: 8px; background: #fff; border-radius: 10px; border: 1px solid #ececec; }
.logo-slot img { max-width: 100%; max-height: 100%; object-fit: contain; filter: grayscale(100%); opacity: 0.6; }
.fade { position: absolute; top: 0; bottom: 0; width: 80px; pointer-events: none; z-index: 1; }
.fade-left { left: 0; background: linear-gradient(to right, var(--color-bg-alt), transparent); }
.fade-right { right: 0; background: linear-gradient(to left, var(--color-bg-alt), transparent); }

.intro-section { padding: 80px 0; }
.intro-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 4rem; align-items: center; }
.intro-text { text-align: left; }
.intro-text h2 { font-size: clamp(1.9rem,4vw,2.8rem); line-height: 1.1; margin-bottom: 1.25rem; }
.intro-text .lead { font-size: 1.1rem; line-height: 1.7; color: #444; max-width: 520px; margin-bottom: 1.75rem; }
.intro-tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem; }
.intro-tags li { font-size: 0.85rem; font-weight: 600; color: var(--color-primary-dark); background: rgba(0,188,212,0.1); border: 1px solid rgba(0,188,212,0.25); padding: 0.4rem 0.85rem; border-radius: 999px; }
.intro-visual { display: flex; align-items: center; justify-content: center; background-image: linear-gradient(160deg,#f1f7f9,#dbeaee); border: 1px solid rgba(0,188,212,0.12); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); padding: 2.5rem; min-height: 380px; }
.intro-visual img { max-height: 360px; object-fit: contain; filter: drop-shadow(0 20px 40px rgba(0,60,80,0.18)); }

.benefits-section { padding: 80px 0; background: #fff; }
.benefits-head { text-align: center; margin-bottom: 2.5rem; }
.benefits-head h2 { font-size: clamp(1.6rem,3vw,2.2rem); }
.benefits-lead { max-width: 620px; margin: 1rem auto 0; font-size: 1.05rem; line-height: 1.6; color: #555; }
.benefits-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.75rem; }
.benefit-card { text-align: left; padding: 2rem; background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s; }
.benefit-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: rgba(0,188,212,0.3); }
.benefit-icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background-image: linear-gradient(135deg, rgba(0,188,212,0.14), rgba(0,188,212,0.04)); border: 1px solid rgba(0,188,212,0.18); border-radius: 16px; margin-bottom: 1.1rem; }
.benefit-card h3 { font-size: 1.1rem; color: #333; margin-bottom: 0.4rem; }
.benefit-card p { font-size: 0.92rem; color: #666; line-height: 1.55; }

.products-section { padding: 80px 0; text-align: center; background: var(--color-bg-alt); }
.products-section h2 { margin-bottom: 3rem; }
.products-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; text-align: left; }
.product-card { background: #fff; border: 1px solid rgba(13,31,36,0.06); border-radius: var(--radius-lg); padding: 1.75rem; box-shadow: var(--shadow-md); transition: transform 0.25s, box-shadow 0.25s; }
.product-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-6px); }
.product-card img { width: 100%; height: 200px; object-fit: contain; border-radius: var(--radius-md); background-image: linear-gradient(160deg,#f3f8fa,#e6f0f3); margin-bottom: 1.5rem; }
.product-card h3 { font-size: 1.3rem; color: var(--color-primary); text-transform: lowercase; margin-bottom: 0.75rem; }
.product-card p { margin-bottom: 0.75rem; color: #333; }
.product-card .version { font-size: 0.9rem; color: #666; }
.product-card a { color: var(--color-primary-dark); font-weight: 500; display: inline-block; margin-top: 0.5rem; }

.contact-section { padding: 80px 0; background: linear-gradient(rgba(0,90,120,0.7), rgba(0,50,70,0.8)), url('/shore.jpg') center top / cover no-repeat; }
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.contact-info h2 { font-size: 2rem; color: #fff; margin-bottom: 1rem; }
.contact-info h3 { font-size: 1.2rem; color: #fff; line-height: 1.4; margin-bottom: 1.5rem; }
.contact-info p { margin-bottom: 0.5rem; color: #fff; }
.contact-info a { color: var(--color-primary); }
.contact-form form { display: flex; flex-direction: column; gap: 1rem; }
.contact-form input, .contact-form textarea { background: rgba(255,255,255,0.7); border: none; border-bottom: 1px solid #ccc; border-radius: 0; padding: 0.85rem 0.5rem; color: #6b6b6b; font-family: inherit; font-size: 1rem; }
.contact-form input:focus, .contact-form textarea:focus { outline: none; border-bottom-color: var(--color-primary); }
.contact-form textarea { min-height: 120px; resize: vertical; }
.consent { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.85rem; color: #fff; }
.consent a { color: var(--color-primary); }
@media (max-width: 900px) { .products-grid, .benefits-grid, .contact-grid { grid-template-columns: 1fr; } .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
