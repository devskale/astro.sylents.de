---
import SiteLayout from '../layouts/SiteLayout.astro';
import '../styles/tokens.css';

const products = [
  {
    id: 'outboard',
    name: 'Sylents Außenboarder',
    tag: 'Leicht. Mobil. In Minuten startklar.',
    power: '1,2–4,5 kW',
    img: '/outboard.png',
    points: [
      'Nur 14,6 kg inklusive Batterie – passt auf jedes Dach und jeden Heckspiegel',
      'Geschlossener Jetantrieb: kein Propeller, keine Verletzungsgefahr',
      'Bis zu 50 Minuten Fahrspaß unter Volllast',
      'Blockierungsfrei durch Schilf, Sand und über seichte Ufer',
    ],
  },
  {
    id: 'inboard',
    name: 'Sylents Innenboarder',
    tag: 'Integriert. Wartungsarm. Für geschützte Gewässer.',
    power: '1–10 kW',
    img: '/inboard.png',
    points: [
      'Integrierter, wassergekühlter Elektroantrieb bis 5.000 U/min',
      'Abgestimmtes Gesamtsystem mit durchdachtem Sicherheitskonzept',
      'Alle Komponenten koordiniert und wasserdicht',
      'Wirtschaftliche Alternative für intensive Nutzung',
    ],
  },
  {
    id: 'pod',
    name: 'Sylents Pod-Antrieb',
    tag: 'Kompakt. Platzsparend. Für flache Gewässer.',
    power: '1–10 kW',
    img: '/pod.png',
    points: [
      'Leichter, raumsparender Pod-Drive für Segelboote, Hausboote und Yachten',
      'Komplettes Energiemanagement aus einer Hand',
      'Ideal für seichte Gewässer, Schilfzonen und Hafenbecken',
      'Geschlossenes, unzerstörbares Antriebssystem',
    ],
  },
];
---

<SiteLayout title="Produkte | Sylents" description="Elektrische Jetantriebe als Außen-, Innenboarder und Pod – für jedes Freizeitboot auf dem See.">
  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <span class="breadcrumb">Produkte</span>
      <h1>Elektrische Jetantriebe</h1>
      <p>Ein Antriebsprinzip, drei Bauformen – für jedes Freizeitboot den passenden Jet: als Außenboarder, Innenboarder oder Pod-Antrieb.</p>
    </div>
  </section>

  <!-- Warum Jetantriebe -->
  <section class="why-jet">
    <div class="container">
      <div class="why-grid">
        <div>
          <span class="eyebrow">Warum Jet?</span>
          <h2>Warum ein Jetantrieb?</h2>
          <p>Jetantriebe haben keine außen liegenden Propeller – sie sind sicher für Badende, kommen durch Schilf und seichte Ufer und fahren angenehm leise. Sylents macht diese Vorteile erstmals für das breite Freizeitboote-Segment zugänglich: einfach zu installieren, robust im Betrieb und eine echte Alternative zum Propeller.</p>
        </div>
        <ul class="why-points">
          <li><strong>Sicher</strong> – keine beweglichen Teile außen, kein Verletzungsrisiko</li>
          <li><strong>Blockierungsfrei</strong> – kommt durch Schilf, Sand und flache Ufer</li>
          <li><strong>Leise</strong> – geräuscharmer Elektroantrieb, emissionsfrei</li>
          <li><strong>Wartungsarm</strong> – kein Öl, keine Winterisierung</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Product detail sections -->
  {products.map((p, i) => (
    <section id={p.id} class="product-detail" data-reverse={i % 2 === 1}>
      <div class="container detail-grid">
        <div class="detail-visual">
          <img src={p.img} alt={p.name} />
        </div>
        <div class="detail-body">
          <span class="detail-tag">{p.tag}</span>
          <h2>{p.name}</h2>
          <div class="detail-power"><strong>{p.power}</strong> Leistung</div>
          <ul class="detail-points">
            {p.points.map((pt) => (
              <li>{pt}</li>
            ))}
          </ul>
          <a href="/#contact" class="btn">Anfrage senden</a>
        </div>
      </div>
    </section>
  ))}
</SiteLayout>

<style>
.why-jet { padding: 80px 0; background: var(--color-bg-alt); }
.why-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
.why-jet h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 1rem; }
.why-jet p { color: #444; line-height: 1.8; font-size: 1.05rem; }
.why-points { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
.why-points li {
  background: #fff; border: 1px solid rgba(13,31,36,0.06);
  border-radius: var(--radius-md); box-shadow: var(--shadow-sm);
  padding: 1rem 1.25rem; color: #444; font-size: 0.95rem;
}
.why-points li strong { color: var(--color-primary-dark); }

.product-detail { padding: 80px 0; }
.detail-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem; align-items: center; }
.product-detail[data-reverse="true"] .detail-grid { direction: rtl; }
.product-detail[data-reverse="true"] .detail-grid > * { direction: ltr; }
.detail-visual {
  background-image: linear-gradient(160deg, #f1f7f9, #dbeaee);
  border: 1px solid rgba(0,188,212,0.12);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 2.5rem; min-height: 340px;
  display: flex; align-items: center; justify-content: center;
}
.detail-visual img { max-height: 320px; object-fit: contain; filter: drop-shadow(0 20px 40px rgba(0,60,80,0.18)); }
.detail-tag { display: inline-block; color: var(--color-primary); font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; }
.detail-body h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); color: var(--color-primary-dark); margin-bottom: 0.75rem; }
.detail-power {
  display: inline-flex; align-items: baseline; gap: 0.4rem;
  background: rgba(0,188,212,0.1); border: 1px solid rgba(0,188,212,0.25);
  border-radius: var(--radius-pill); padding: 0.4rem 1rem;
  font-size: 0.9rem; color: #555; margin-bottom: 1.5rem;
}
.detail-power strong { color: var(--color-primary-dark); font-size: 1.05rem; }
.detail-points { list-style: none; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 0.6rem; }
.detail-points li {
  position: relative; padding-left: 1.6rem; color: #444; line-height: 1.6; font-size: 0.98rem;
}
.detail-points li::before {
  content: ''; position: absolute; left: 0; top: 0.55em;
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--color-primary);
}
@media (max-width: 800px) {
  .why-grid { grid-template-columns: 1fr; gap: 2rem; }
  .detail-grid { grid-template-columns: 1fr; gap: 2rem; }
  .product-detail[data-reverse="true"] .detail-grid { direction: ltr; }
  .detail-visual { min-height: 260px; padding: 1.5rem; }
}
</style>
